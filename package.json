{
  "name": "incorutas-photo-sync",
  "version": "2.0.0",
  "description": "Middleware para sincronizar fotos de Supabase Storage al servidor de archivos local e interactuar con carpetas de trabajo",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "cross-env NODE_ENV=development node src/index.js",
    "backfill": "node scripts/backfill.js",
    "backfill:dry": "node scripts/backfill.js --dry-run",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ tests/",
    "prepare": "node -e \"try{require('husky')}catch{}\""
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.43.4",
    "bullmq": "^5.78.1",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.11.1",
    "winston": "^3.13.0",
    "winston-daily-rotate-file": "^5.0.0",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "lint-staged": {
    "*.{js}": [
      "eslint"
    ]
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.9",
    "cross-env": "^10.1.0",
    "eslint": "^10.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "vitest": "^4.1.9"
  }
}
