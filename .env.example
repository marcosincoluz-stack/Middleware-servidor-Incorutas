# ── Supabase ──
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here
SUPABASE_BUCKET=evidence

# ── Seguridad y Servidor ──
PORT=3000
API_TOKEN=generate-a-64-char-hex-token-here

# ── Almacenamiento ──
TRABAJOS_BASE_PATH=/mnt/trabajos
MIN_DISK_MB=500

# ── Redis (BullMQ) ──
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password-here

# ── Operaciones ──
ENABLE_FOLDER_MOVE=false
MAX_FILE_SIZE_MB=50
MAX_EVIDENCES_PER_JOB=150
DISK_CHECK_INTERVAL=10
PART_CLEANUP_ON_STARTUP=true
BACKFILL_MAX_JOBS=100
BACKFILL_MAX_PENDING=200

# ── Seguridad de archivos ──
# Extensiones de imagen permitidas para descarga (separadas por comas, sin punto)
# Si no se define, se usan las extensiones por defecto
ALLOWED_IMAGE_EXTENSIONS=jpg,jpeg,png,webp,heic,heif,gif,bmp,tiff,tif,pdf

# ── Logging ──
LOG_LEVEL=info

# ── Circuit Breaker ──
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_RESET_MS=30000

# ── Polling ──
POLLING_ENABLED=true
# Intervalo rápido: detección de jobs approved para descarga de imágenes
POLLING_INTERVAL_MS=30000
# Intervalo lento: paid (move), stale (auto-heal), planos (filesystem)
SLOW_POLLING_INTERVAL_MS=300000
POLLING_FAILURE_ALERT_THRESHOLD=3
POLLING_ALERT_COOLDOWN_MS=300000

# ── Polling Adaptativo ──
# Reduce automáticamente la frecuencia de polling fuera de horario laboral.
# En horario laboral siempre mantiene el intervalo base (POLLING_INTERVAL_MS).
ADAPTIVE_POLLING_ENABLED=true
ADAPTIVE_IDLE_THRESHOLD=3
ADAPTIVE_MAX_INTERVAL_MS=1800000
BUSINESS_HOURS_START=7
BUSINESS_HOURS_END=21
# Días laborables (0=Domingo, 1=Lunes, ..., 6=Sábado)
BUSINESS_DAYS=1,2,3,4,5

# ── Sanitización de Privacidad ──
# Elimina metadatos EXIF (GPS, modelo dispositivo) de las fotos al descargarlas
STRIP_EXIF_ENABLED=true

# ── Health Check ──
HEALTH_PING_TIMEOUT_MS=3000

# ── Planos (subida de PDF a Supabase Storage) ──
# Activa la subida automática de planos desde el servidor a Supabase
ENABLE_PLANO_UPLOAD=true
# Bucket de Supabase donde se guardan los planos (distinto del de evidencias)
SUPABASE_PLANOS_BUCKET=mounting-orders
# Subcarpeta del proyecto donde buscar el PDF del plano
PLANO_SCAN_SUBFOLDER=FABRICACION
# Tamaño máximo del plano en MB (se lee a Buffer para validar)
PLANO_MAX_SIZE_MB=50
# Máximo de planos por job (se suben hasta este número; el resto se omite con alerta)
PLANO_MAX_PLANOS_PER_JOB=4
# Status de jobs a escanear para subir plano (separados por coma)
PLANO_UPLOAD_STATUSES=pending
# Profundidad máxima al buscar la carpeta del proyecto (anidamiento)
PROJECT_FOLDER_MAX_DEPTH=4
# TTL en ms del índice cacheado de carpetas (reduce readdir en SMB)
PLANO_INDEX_TTL_MS=300000

# ── BullMQ Worker ──
STALLED_INTERVAL_MS=30000
LOCK_DURATION_MS=60000

# ── Node ──
# NODE_ENV=production

# ── Notificaciones (Telegram) ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=