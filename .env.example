# ── Supabase ──
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here
SUPABASE_BUCKET=evidence

# ── Seguridad y Servidor ──
PORT=3000
API_TOKEN=generate-a-64-char-hex-token-here

# ── Almacenamiento ──
TRABAJOS_BASE_PATH=/mnt/trabajos
MIN_DISK_MB=500

# ── Redis (BullMQ) ──
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password-here

# ── Operaciones ──
ENABLE_FOLDER_MOVE=false
MAX_FILE_SIZE_MB=50
MAX_EVIDENCES_PER_JOB=150
DISK_CHECK_INTERVAL=10
PART_CLEANUP_ON_STARTUP=true
BACKFILL_MAX_JOBS=100
BACKFILL_MAX_PENDING=200

# ── Logging ──
LOG_LEVEL=info

# ── Circuit Breaker ──
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_RESET_MS=30000

# ── Polling ──
POLLING_ENABLED=true
POLLING_INTERVAL_MS=30000
POLLING_FAILURE_ALERT_THRESHOLD=3
POLLING_ALERT_COOLDOWN_MS=300000

# ── Health Check ──
HEALTH_PING_TIMEOUT_MS=3000

# ── BullMQ Worker ──
STALLED_INTERVAL_MS=30000
LOCK_DURATION_MS=60000

# ── Node ──
# NODE_ENV=production

# ── Notificaciones (Telegram) ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=